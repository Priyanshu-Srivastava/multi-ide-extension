{
  "name": "omni-cursor-team-b",
  "displayName": "Omni IDE — Team B (Cursor)",
  "description": "Omni multi-IDE extension for Team B — Cursor build.",
  "version": "1.0.3",
  "publisher": "Priyanshu",
  "license": "MIT",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other", "AI"],
  "activationEvents": ["onStartupFinished"],
  "keywords": ["omni", "mcp", "team-b", "cursor"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omni-explorer",
          "title": "Omni IDE",
          "icon": "$(extensions)"
        }
      ]
    },
    "views": {
      "omni-explorer": [
        {
          "id": "omni-features-team-b",
          "name": "Team B",
          "type": "tree"
        }
      ]
    },
    "commands": [
      { "command": "omni.team-b.showInfo",             "title": "Omni: Show Extension Info" },
      { "command": "omni.team-b.feature.openMath",     "title": "Omni: Open Math Panel"      }
    ]
  },
  "repository": { "type": "git", "url": "https://github.com/your-org/multi-ide-extension" }
}
