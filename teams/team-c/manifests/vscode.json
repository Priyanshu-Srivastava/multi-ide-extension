{
  "name": "omni-vscode-team-c",
  "displayName": "Omni IDE — Team C",
  "description": "Omni multi-IDE extension for Team C. Provides MCP tool integration and shared workspace capabilities.",
  "version": "1.0.5",
  "publisher": "Priyanshu",
  "license": "MIT",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other", "AI"],
  "activationEvents": ["onStartupFinished"],
  "keywords": ["omni", "mcp", "team-c"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "omni-explorer",
          "title": "Omni IDE",
          "icon": "$(extensions)"
        }
      ]
    },
    "views": {
      "omni-explorer": [
        {
          "id": "omni-features-team-c",
          "name": "Team C",
          "type": "tree"
        }
      ]
    },
    "commands": [
      { "command": "omni.team-c.showInfo",             "title": "Omni: Show Extension Info" },
      { "command": "omni.team-c.feature.openMath",     "title": "Omni: Open Math Panel"      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "omni.team-c.showInfo",
          "when": "view == omni-features-team-c",
          "group": "navigation@1"
        },
        {
          "command": "omni.team-c.feature.openMath",
          "when": "view == omni-features-team-c",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "omni.team-c.feature.openMath",
          "when": "view == omni-features-team-c && viewItem == feature",
          "group": "inline@1"
        }
      ]
    }
  },
  "repository": { "type": "git", "url": "https://github.com/your-org/multi-ide-extension" }
}
